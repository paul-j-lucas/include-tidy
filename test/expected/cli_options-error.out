$ include-tidy -Xtidy --align-column
include-tidy: error: "--align-column/-a" requires an argument

$ include-tidy -Xtidy --align-column=
include-tidy: error: "": invalid integer

$ include-tidy -Xtidy --align-column=X
include-tidy: error: "X": invalid integer

$ include-tidy -Xtidy -a
include-tidy: error: "-a" requires an argument

$ include-tidy -Xtidy -aX
include-tidy: error: "X": invalid integer

$ include-tidy -Xtidy --clang
include-tidy: error: "--clang" requires an argument

$ include-tidy -Xtidy --clang=
include-tidy: error: "--clang" requires an argument

$ include-tidy -Xtidy -C
include-tidy: error: "-C" requires an argument

$ include-tidy -Xtidy --comment-style
include-tidy: error: "--comment-style/-s" requires an argument

$ include-tidy -Xtidy --comment-style=
include-tidy: error: "--comment-style/-s" requires an argument

$ include-tidy -Xtidy --comment-style=X
include-tidy: error: "X": invalid value for --comment-style/-s; must be one of "//", "/*", or "none"

$ include-tidy -Xtidy -s
include-tidy: error: "-s" requires an argument

$ include-tidy -Xtidy -sX
include-tidy: error: "X": invalid value for --comment-style/-s; must be one of "//", "/*", or "none"

$ include-tidy -Xtidy --config
include-tidy: error: "--config/-c" requires an argument

$ include-tidy -Xtidy --config=
include-tidy: error: "--config/-c" requires an argument

$ include-tidy -Xtidy -c
include-tidy: error: "-c" requires an argument

$ include-tidy -Xtidy --line-length
include-tidy: error: "--line-length/-l" requires an argument

$ include-tidy -Xtidy --line-length=
include-tidy: error: "": invalid integer

$ include-tidy -Xtidy --line-length=X
include-tidy: error: "X": invalid integer

$ include-tidy -Xtidy -l
include-tidy: error: "-l" requires an argument

$ include-tidy -Xtidy -lX
include-tidy: error: "X": invalid integer

$ include-tidy --help X
usage: include-tidy [-Xtidy tidy-option]... [clang-option]... source-file
       include-tidy other-option

tidy options:
  --align-column=ARG  (-a) Align comments to this column; default=80.
  --all-includes      (-A) Print all includes, not just those in violation.
  --clang=ARG         (-C) Path of clang to use or "none"; default="clang".
  --color=ARG         (-k) When to colorize output; default="not_file".
  --comment-style=ARG (-s) Comment style: "//", "/*", or "none".
  --config=ARG        (-c) Configuration file path.
  --directory=ARG     (-d) Change directory before tidying.
  --error=ARG         (-e) When to exit with a non-zero status.
  --line-length=ARG   (-l) Line length; default=80.
  --no-config-layers  (-L) Don't do configuration file layering.
  --verbose=ARG       (-V) Print verbose output.

other options:
  --help                   Print this help and exit.
  --version                Print version and exit.

include-tidy home page: https://github.com/paul-j-lucas/include-tidy
Report bugs to: https://github.com/paul-j-lucas/include-tidy/issues

$ include-tidy --help=X
include-tidy: "help=X": invalid option; use --help for help

$ include-tidy --help --version
include-tidy: error: --help/-h can be given only by itself

$ include-tidy -x
include-tidy: error: "-x" requires an argument

$ include-tidy -xX
include-tidy: error: "X": invalid value for -x; must be either "c" or "c++"

$ include-tidy --version X
usage: include-tidy [-Xtidy tidy-option]... [clang-option]... source-file
       include-tidy other-option

tidy options:
  --align-column=ARG  (-a) Align comments to this column; default=80.
  --all-includes      (-A) Print all includes, not just those in violation.
  --clang=ARG         (-C) Path of clang to use or "none"; default="clang".
  --color=ARG         (-k) When to colorize output; default="not_file".
  --comment-style=ARG (-s) Comment style: "//", "/*", or "none".
  --config=ARG        (-c) Configuration file path.
  --directory=ARG     (-d) Change directory before tidying.
  --error=ARG         (-e) When to exit with a non-zero status.
  --line-length=ARG   (-l) Line length; default=80.
  --no-config-layers  (-L) Don't do configuration file layering.
  --verbose=ARG       (-V) Print verbose output.

other options:
  --help                   Print this help and exit.
  --version                Print version and exit.

include-tidy home page: https://github.com/paul-j-lucas/include-tidy
Report bugs to: https://github.com/paul-j-lucas/include-tidy/issues

$ include-tidy --version=X
include-tidy: "version=X": invalid option; use --help for help

