$ include-tidy -Xtidy -c
include-tidy: error: "-c" requires an argument

$ include-tidy -Xtidy --directory
include-tidy: error: "--directory/-d" requires an argument

$ include-tidy -Xtidy --directory=
include-tidy: error: "--directory/-d" requires an argument

$ include-tidy -Xtidy -d
